FROM node:20-alpine

WORKDIR /app

# Install standard alpine build tools if needed for sqlite binaries
RUN apk add --no-cache libc6-compat

# Intentionally DO NOT copy package.json!
# If we run npm ci, it installs the Next.js compiler, React, and Recharts, bloating the image to 1.19GB.
# We exclusively need sqlite to run the background loop.
RUN npm install sqlite sqlite3

# Copy the standalone background worker
COPY worker.mjs ./

# Start the infinite loop process
CMD ["node", "worker.mjs"]
